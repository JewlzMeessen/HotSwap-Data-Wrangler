{
  "name": "hotswap",
  "version": "1.0.0",
  "description": "HotSwap - Automatische Datensicherung von SD & CFexpress-Karten",
  "author": "HotSwap",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.hotswap.app",
    "productName": "HotSwap",
    "publish": null,
    "mac": {
      "category": "public.app-category.photography",
      "icon": "assets/icon.icns",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": ["nsis", "portable"]
    },
    "files": ["src/**/*", "assets/**/*"]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
